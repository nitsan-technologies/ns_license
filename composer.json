{
  "name": "nitsan/ns-license",
  "type": "typo3-cms-extension",
  "description": "Manage License(s) of your purchased from T3Planet such as TYPO3 Templates and TYPO3 Extensions.",
  "keywords": [
    "TYPO3 CMS",
    "license",
    "bootstrap",
    "responsive",
    "frontend",
    "theme",
    "template",
    "ns"
  ],
  "homepage": "https://t3planet.com",
  "authors": [
    {
        "name": "Team T3Planet",
        "email": "support@t3planet.com",
        "role": "Developer",
        "homepage": "https://t3planet.com"
    }
  ],
  "support": {
    "issues": "https://github.com/nitsan-technologies/ns_license/issues"
  },
  "license": "MIT",
  "require": {
    "typo3/cms-core": "^12 || ^13 || ^14",
    "typo3/cms-extensionmanager": "^12 || ^13 || ^14"
  },
  "autoload": {
    "psr-4": {
      "NITSAN\\NsLicense\\": "Classes/"
    }
  },
  "replace": {
      "typo3-ter/ns-license": "self.version"
  },
  "config": {
    "vendor-dir": ".Build/vendor/",
    "bin-dir": ".Build/bin/"
  },
  "extra": {
      "typo3/cms": {
          "cms-package-dir": "{$vendor-dir}/typo3/cms",
          "web-dir": ".Build/public",
          "extension-key": "ns_license"
      }
  }
}
